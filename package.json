{
  "name": "ngx-unicode-spinners-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build ngx-unicode-spinners",
    "build:demo": "ng build demo",
    "watch": "ng build ngx-unicode-spinners --watch --configuration development",
    "test": "ng test",
    "lint": "eslint projects",
    "format:check": "prettier --check \"projects/**/*.{ts,html,css,md}\"",
    "format": "prettier --write \"projects/**/*.{ts,html,css,md}\""
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "dependencies": {
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/forms": "^22.0.7",
    "@angular/platform-browser": "^22.0.7",
    "@angular/router": "^22.0.7",
    "ng-packagr": "^22.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "@eslint/js": "^9.39.3",
    "angular-eslint": "^22.1.0",
    "eslint": "^9.39.3",
    "jsdom": "^28.1.0",
    "lefthook": "^2.1.2",
    "prettier": "^3.8.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.0.18"
  }
}
